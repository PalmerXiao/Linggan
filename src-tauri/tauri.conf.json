{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "灵感桌面助手",
  "version": "0.1.0",
  "identifier": "com.linggan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "灵感桌面助手",
        "width": 400,
        "height": 160,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
